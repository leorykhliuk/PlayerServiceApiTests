<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Player API Suite" parallel="methods" thread-count="3" verbose="1">
    <listeners>
        <listener class-name="listeners.LoggingTestListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>
    <test name="Player API Tests">
        <classes>
            <class name="tests.CreatePlayerTest"/>
            <class name="tests.DeletePlayerTest"/>
            <class name="tests.GetPlayerByPlayerIdTest"/>
            <class name="tests.GetAllPlayersTest"/>
            <class name="tests.UpdatePlayerTest"/>
        </classes>
    </test>
</suite>
